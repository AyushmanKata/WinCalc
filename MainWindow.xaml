<Window x:Class="WinCalc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="380" Height="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CardBg}"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Border Background="{DynamicResource CardBg}"
            BorderBrush="{DynamicResource OpBg}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBg}"
                    Padding="8,6"
                    MouseLeftButtonDown="TitleBar_Drag">
				<Grid>
					<!-- Hamburger pinned left -->
					<StackPanel HorizontalAlignment="Left"
								VerticalAlignment="Center"
								Orientation="Horizontal">
						<Button x:Name="btnMenu"
								Style="{StaticResource IconBtn}"
								Height="30"
								Click="Menu_Click">
							<TextBlock Text="&#8801;"
									   Foreground="{DynamicResource SubFg}"
									   FontSize="18"
									   Margin="0,2,0,0"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"/>
						</Button>
					</StackPanel>

					<!-- Mode selector absolutely centered -->
					<ComboBox x:Name="cmbMode"
							  Style="{StaticResource ThemedCombo}"
							  HorizontalAlignment="Center"
							  VerticalAlignment="Center"
							  SelectionChanged="Mode_Changed"
							  SelectedIndex="0"
							  MinWidth="120">
						<ComboBoxItem Content="Basic"/>
						<ComboBoxItem Content="Advanced"/>
					</ComboBox>

					<!-- Minimize + Close pinned right -->
					<StackPanel HorizontalAlignment="Right"
								VerticalAlignment="Center"
								Orientation="Horizontal">
						<Button Style="{StaticResource IconBtn}"
								Click="Minimize_Click">
							<TextBlock Text="&#8211;"
									   FontSize="14"
									   Foreground="{DynamicResource SubFg}"
									   Margin="0,2,0,0"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"/>
						</Button>
						<Button Style="{StaticResource IconBtn}"
								Margin="2,0,0,0"
								Click="Close_Click">
							<Border Background="#CC3333" CornerRadius="10"
									Width="18" Height="18">
								<TextBlock Text="&#10005;" FontSize="9"
										   Foreground="White"
										   HorizontalAlignment="Center"
										   VerticalAlignment="Center"/>
							</Border>
						</Button>
					</StackPanel>
				</Grid>
            </Border>

            <!-- History + Display -->
            <Border Grid.Row="1" Background="{DynamicResource HistBg}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="histScroll"
                                  Grid.Row="0"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14,8,14,0">
                        <StackPanel x:Name="histPanel"/>
                    </ScrollViewer>

                    <TextBlock x:Name="txtPreview"
                               Grid.Row="1"
                               FontSize="22"
                               FontFamily="Segoe UI"
                               Foreground="{DynamicResource SubFg}"
                               TextAlignment="Right"
                               TextTrimming="CharacterEllipsis"
                               Margin="14,0,10,0"
                               Opacity="0.75"/>

                    <Grid Grid.Row="2" Margin="14,0,10,10">
                        <TextBox x:Name="txtExpr"
                                 FontSize="32" FontWeight="Bold"
                                 FontFamily="Segoe UI"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource Fg}"
                                 CaretBrush="{DynamicResource AccentBg}"
                                 VerticalAlignment="Center"
                                 MinHeight="44"
                                 TextWrapping="Wrap"
                                 PreviewTextInput="txtExpr_PreviewInput"
                                 TextChanged="Expr_Changed"
                                 KeyDown="Expr_KeyDown"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Button Pad -->
            <Border Grid.Row="2"
                    Background="{DynamicResource CardBg}"
                    Padding="6,4,6,8">
                <Grid x:Name="btnGrid"/>
            </Border>
        </Grid>
    </Border>
</Window>
