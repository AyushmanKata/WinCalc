<Window x:Class="WinCalc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="380" Height="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CardBg}"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Border Background="{DynamicResource CardBg}"
            BorderBrush="{DynamicResource OpBg}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBg}"
                    Padding="8,6"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnBack" Grid.Column="0"
                            Style="{StaticResource IconBtn}"
                            Content="&#8592;" FontSize="16"
                            IsEnabled="False" Click="Back_Click"/>

                    <Button x:Name="btnFwd" Grid.Column="1"
                            Style="{StaticResource IconBtn}"
                            Content="&#8594;" FontSize="16"
                            IsEnabled="False" Margin="2,0,0,0"
                            Click="Fwd_Click"/>

                    <ComboBox x:Name="cmbMode" Grid.Column="2"
                              Style="{StaticResource ThemedCombo}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              SelectionChanged="Mode_Changed"
                              SelectedIndex="0"
                              MinWidth="120">
                        <ComboBoxItem Content="Basic"/>
                        <ComboBoxItem Content="Advanced"/>
                    </ComboBox>

                    <Button x:Name="btnMenu" Grid.Column="3"
                            Style="{StaticResource IconBtn}"
                            Content="&#8801;" FontSize="18"
                            Click="Menu_Click"/>

                    <Button Grid.Column="4"
                            Style="{StaticResource IconBtn}"
                            Margin="2,0,0,0"
                            Click="Close_Click">
                        <Border Background="#CC3333" CornerRadius="10"
                                Width="18" Height="18">
                            <TextBlock Text="&#10005;" FontSize="9"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Button>
                </Grid>
            </Border>

            <!-- History + Display -->
            <Border Grid.Row="1" Background="{DynamicResource HistBg}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="histScroll"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14,8,14,0">
                        <StackPanel x:Name="histPanel"/>
                    </ScrollViewer>

                    <Grid Grid.Row="1" Margin="14,4,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtExpr"
                                 FontSize="32" FontWeight="Bold"
                                 FontFamily="Segoe UI"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource Fg}"
                                 CaretBrush="{DynamicResource AccentBg}"
                                 VerticalAlignment="Center"
                                 MinHeight="44"
                                 TextWrapping="Wrap"
                                 PreviewTextInput="txtExpr_PreviewInput"
                                 TextChanged="Expr_Changed"
                                 KeyDown="Expr_KeyDown"/>
                        <Button Grid.Column="1"
                                Style="{StaticResource IconBtn}"
                                Width="36" Height="36"
                                VerticalAlignment="Bottom"
                                Click="Backspace_Click">
                            <TextBlock Text="&#9003;" FontSize="18"
                                       Foreground="{DynamicResource SubFg}"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Button Pad -->
            <Border Grid.Row="2"
                    Background="{DynamicResource CardBg}"
                    Padding="6,4,6,8">
                <Grid x:Name="btnGrid"/>
            </Border>
        </Grid>
    </Border>
</Window>
